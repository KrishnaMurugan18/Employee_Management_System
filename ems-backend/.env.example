# Copy this file to .env (or set as real environment variables in your hosting provider)

# Server
PORT=8080

# Database (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/ems_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
DDL_AUTO=update

# JWT — generate your own 256-bit base64 secret for production
JWT_SECRET=dGhpc0lzQVZlcnlMb25nU2VjcmV0S2V5Rm9ySldUU2lnbmluZ1B1cnBvc2VzT25seTIwMjU=
JWT_ACCESS_EXPIRY=3600000
JWT_REFRESH_EXPIRY=604800000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads/profile-images

# Default admin seeded on first startup
ADMIN_EMAIL=admin@ems.com
ADMIN_PASSWORD=Admin@123

LOG_LEVEL=INFO
